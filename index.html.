<!doctype html>
<html lang="id">
 <head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Misi Agen Logika - Website Sekolah</title>
  <script src="https://cdn.tailwindcss.com/3.4.17"></script>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700;900&amp;display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/lucide@0.263.0/dist/umd/lucide.min.js"></script>
  <style>
        body { font-family: 'DM Sans', sans-serif; }
        .screen { display: none; animation: fadeIn 0.4s ease; }
        .screen.active { display: flex; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
        @keyframes pulse-glow { 0%,100% { box-shadow: 0 0 20px rgba(99,102,241,0.3); } 50% { box-shadow: 0 0 40px rgba(99,102,241,0.6); } }
        .glow { animation: pulse-glow 2s infinite; }
        @keyframes pop { 0% { transform: scale(0); } 70% { transform: scale(1.2); } 100% { transform: scale(1); } }
        .pop { animation: pop 0.3s ease; }
        .bead { transition: transform 0.15s; }
        .bead:active { transform: scale(0.9); }
        .bucket-fill { transition: height 0.3s linear; }
    </style>
 </head>
 <body class="min-h-screen bg-gradient-to-tr from-indigo-100 via-slate-50 to-purple-100 flex items-center justify-center p-4 text-slate-800">

  <!-- SCREEN 0: WELCOME -->
  <div id="screen-0" class="screen active flex-col items-center text-center max-w-md w-full gap-6 bg-white/95 backdrop-blur-md p-8 rounded-3xl shadow-xl border border-white/50">
   <div class="bg-indigo-100 text-indigo-800 px-6 py-2 rounded-full text-xs font-bold uppercase tracking-widest shadow-sm">
     🏫 MEDIA EDUKASI SEKOLAH
   </div>
   <h1 class="text-3xl md:text-4xl font-black leading-tight text-indigo-950">
     Misi Agen Logika
   </h1>
   <p class="text-sm md:text-base text-slate-600">
     Selesaikan 4 tantangan berpikir komputasional untuk membuktikan ketajaman logika berpikirmu!
   </p>
   <div class="w-full mt-2">
     <input id="name-input" type="text" placeholder="Masukkan Nama Agen Kamu..." class="w-full px-5 py-3 rounded-2xl border-2 border-indigo-200 focus:border-indigo-500 focus:outline-none text-center text-lg bg-white shadow-inner">
   </div>
   <button id="start-btn" disabled class="w-full px-8 py-4 rounded-2xl font-bold text-lg transition-all disabled:opacity-40 disabled:cursor-not-allowed bg-indigo-600 text-white hover:bg-indigo-700 shadow-lg shadow-indigo-200 glow">
     Mulai Misi 🚀
   </button>
   <p class="text-xs text-slate-400 mt-2">
     Dibuat untuk Media Pembelajaran Informatika Sekolah
   </p>
  </div>

  <!-- SCREEN 1: LEVEL 1 -->
  <div id="screen-1" class="screen flex-col items-center text-center max-w-md w-full gap-4 bg-white/95 backdrop-blur-md p-8 rounded-3xl shadow-xl border border-white/50">
   <div class="w-full flex justify-between items-center">
     <span class="text-xs font-bold bg-indigo-100 text-indigo-700 px-3 py-1 rounded-full">LEVEL 1</span> 
     <span id="score-1" class="text-xs font-bold bg-emerald-100 text-emerald-700 px-3 py-1 rounded-full">Skor: 0</span>
   </div>
   <h2 class="text-2xl font-black text-indigo-950">Tantangan 1: Algoritma Gelang</h2>
   <p class="text-sm text-slate-600">Klik manik-manik di bawah secara berurutan sesuai pola target agar gelang tersusun sempurna!</p>
   <div class="bg-indigo-50/50 border border-indigo-100 rounded-2xl p-4 w-full">
    <p class="text-xs font-black mb-2 text-indigo-600 tracking-wider">POLA TARGET: 🔴🟡🟢🔴🟡🟢</p>
    <div id="bracelet" class="flex gap-2 justify-center min-h-[48px] items-center flex-wrap">
      <span class="text-slate-400 text-sm" id="bracelet-placeholder">Klik manik di bawah...</span>
    </div>
   </div>
   <div class="flex gap-3 mt-2">
     <button onclick="addBead('red')" class="bead px-4 py-3 rounded-xl font-bold bg-red-500 text-white shadow-lg shadow-red-200 hover:bg-red-600">🔴 Merah</button> 
     <button onclick="addBead('yellow')" class="bead px-4 py-3 rounded-xl font-bold bg-yellow-400 text-gray-800 shadow-lg shadow-yellow-100 hover:bg-yellow-500">🟡 Kuning</button> 
     <button onclick="addBead('green')" class="bead px-4 py-3 rounded-xl font-bold bg-green-500 text-white shadow-lg shadow-green-200 hover:bg-green-600">🟢 Hijau</button>
   </div>
   <p id="bead-feedback" class="text-sm font-medium h-6"></p>
  </div>

  <!-- SCREEN 2: LEVEL 2 -->
  <div id="screen-2" class="screen flex-col items-center text-center max-w-md w-full gap-4 bg-white/95 backdrop-blur-md p-8 rounded-3xl shadow-xl border border-white/50">
   <div class="w-full flex justify-between items-center">
     <span class="text-xs font-bold bg-indigo-100 text-indigo-700 px-3 py-1 rounded-full">LEVEL 2</span> 
     <span id="score-2" class="text-xs font-bold bg-emerald-100 text-emerald-700 px-3 py-1 rounded-full">Skor: 0</span>
   </div>
   <h2 class="text-2xl font-black text-indigo-950">Tantangan 2: Optimasi Ember</h2>
   <p class="text-sm text-slate-600">Klik tombol ember (A, B, C) di bawah untuk mengisi air di keran secara bergantian dan efisien!</p>
   <div class="grid grid-cols-2 gap-3 w-full">
    <div class="bg-blue-50/70 border border-blue-100 rounded-2xl p-3 text-center">
     <p class="text-xs font-black text-blue-600 mb-1">KERAN 1</p>
     <div id="tap1-status" class="text-sm text-slate-500 font-medium">Kosong</div>
     <div class="h-2 bg-slate-200 rounded-full mt-2 overflow-hidden">
      <div id="tap1-bar" class="h-full bg-blue-500 rounded-full bucket-fill" style="width:0%"></div>
     </div>
    </div>
    <div class="bg-blue-50/70 border border-blue-100 rounded-2xl p-3 text-center">
     <p class="text-xs font-black text-blue-600 mb-1">KERAN 2</p>
     <div id="tap2-status" class="text-sm text-slate-500 font-medium">Kosong</div>
     <div class="h-2 bg-slate-200 rounded-full mt-2 overflow-hidden">
      <div id="tap2-bar" class="h-full bg-blue-500 rounded-full bucket-fill" style="width:0%"></div>
     </div>
    </div>
   </div>
   <div class="flex gap-3 mt-2">
     <button onclick="assignBucket('A')" id="bucket-a-btn" class="px-4 py-3 rounded-xl font-bold bg-white border-2 border-blue-200 hover:bg-blue-50 text-slate-700 shadow-sm">🪣 A (2L)</button> 
     <button onclick="assignBucket('B')" id="bucket-b-btn" class="px-4 py-3 rounded-xl font-bold bg-white border-2 border-blue-200 hover:bg-blue-50 text-slate-700 shadow-sm">🪣 B (2L)</button> 
     <button onclick="assignBucket('C')" id="bucket-c-btn" class="px-4 py-3 rounded-xl font-bold bg-white border-2 border-blue-200 hover:bg-blue-50 text-slate-700 shadow-sm">🪣 C (4L)</button>
   </div>
   <p id="tap-feedback" class="text-sm font-medium h-6"></p>
   <div id="tap-timer" class="text-xs text-slate-400"></div>
  </div>

  <!-- SCREEN 3: LEVEL 3 -->
  <div id="screen-3" class="screen flex-col items-center text-center max-w-md w-full gap-4 bg-white/95 backdrop-blur-md p-8 rounded-3xl shadow-xl border border-white/50">
   <div class="w-full flex justify-between items-center">
     <span class="text-xs font-bold bg-indigo-100 text-indigo-700 px-3 py-1 rounded-full">LEVEL 3</span> 
     <span id="score-3" class="text-xs font-bold bg-emerald-100 text-emerald-700 px-3 py-1 rounded-full">Skor: 0</span>
   </div>
   <h2 class="text-2xl font-black text-indigo-950">Tantangan 3: Kata Rahasia</h2>
   <p class="text-sm text-slate-600">Susun kembali huruf acak menjadi kata <b>"LOGIKA"</b> dengan mengikuti petunjuk posisi berikut:</p>
   <div class="bg-indigo-50/50 border border-indigo-100 rounded-2xl p-4 w-full text-left text-xs space-y-1.5 text-slate-700">
    <p>📌 Huruf <b>L</b> harus di posisi paling pertama.</p>
    <p>📌 Huruf <b>O</b> berada tepat setelah L.</p>
    <p>📌 Huruf <b>G</b> harus berada sebelum I.</p>
    <p>📌 Huruf <b>K</b> dan <b>A</b> di dua posisi terakhir.</p>
   </div>
   <div id="word-slots" class="flex gap-2 justify-center mt-2"></div>
   <div id="letter-bank" class="flex gap-2 justify-center flex-wrap mt-2"></div>
   <p id="word-feedback" class="text-sm font-medium h-6"></p>
  </div>

  <!-- SCREEN 4: LEVEL 4 -->
  <div id="screen-4" class="screen flex-col items-center text-center max-w-md w-full gap-4 bg-white/95 backdrop-blur-md p-8 rounded-3xl shadow-xl border border-white/50">
   <div class="w-full flex justify-between items-center">
     <span class="text-xs font-bold bg-indigo-100 text-indigo-700 px-3 py-1 rounded-full">LEVEL 4</span> 
     <span id="score-4" class="text-xs font-bold bg-emerald-100 text-emerald-700 px-3 py-1 rounded-full">Skor: 0</span>
   </div>
   <h2 class="text-2xl font-black text-indigo-950">Tantangan 4: Peminjaman Ruang</h2>
   <p class="text-sm text-slate-600">Perhatikan tabel jadwal peminjaman di bawah. Cari slot nomor berapa yang kosong (bernilai 0) pada Hari 1 DAN Hari 2!</p>
   <div class="bg-white border border-slate-150 rounded-2xl p-2 w-full overflow-hidden shadow-sm">
    <table class="w-full text-sm text-center">
     <thead>
      <tr class="text-xs text-slate-400 font-bold bg-slate-50">
       <th class="p-2.5">Slot</th>
       <th class="p-2.5">Hari 1</th>
       <th class="p-2.5">Hari 2</th>
      </tr>
     </thead>
     <tbody>
      <tr class="border-t border-slate-100">
       <td class="p-2.5 font-bold text-slate-700">Slot 1</td>
       <td class="p-2.5 text-slate-500">⬛ Terisi (1)</td>
       <td class="p-2.5 text-slate-500">⬜ Kosong (0)</td>
      </tr>
      <tr class="border-t border-slate-100">
       <td class="p-2.5 font-bold text-slate-700">Slot 2</td>
       <td class="p-2.5 text-slate-500">⬜ Kosong (0)</td>
       <td class="p-2.5 text-slate-500">⬜ Kosong (0)</td>
      </tr>
      <tr class="border-t border-slate-100">
       <td class="p-2.5 font-bold text-slate-700">Slot 3</td>
       <td class="p-2.5 text-slate-500">⬛ Terisi (1)</td>
       <td class="p-2.5 text-slate-500">⬛ Terisi (1)</td>
      </tr>
     </tbody>
    </table>
   </div>
   <div class="flex gap-3 mt-2">
     <button onclick="answerRoom(1)" class="px-5 py-3 rounded-xl font-bold bg-white border-2 border-indigo-200 hover:bg-indigo-50 text-slate-700 shadow-sm">Slot 1</button> 
     <button onclick="answerRoom(2)" class="px-5 py-3 rounded-xl font-bold bg-white border-2 border-indigo-200 hover:bg-indigo-50 text-slate-700 shadow-sm">Slot 2</button> 
     <button onclick="answerRoom(3)" class="px-5 py-3 rounded-xl font-bold bg-white border-2 border-indigo-200 hover:bg-indigo-50 text-slate-700 shadow-sm">Slot 3</button>
   </div>
   <p id="room-feedback" class="text-sm font-medium h-6"></p>
  </div>

  <!-- SCREEN 5: DASHBOARD -->
  <div id="screen-5" class="screen flex-col items-center text-center max-w-md w-full gap-4 bg-white/95 backdrop-blur-md p-8 rounded-3xl shadow-xl border border-white/50">
   <div class="bg-indigo-600 text-white text-xs font-bold uppercase tracking-wider px-5 py-2 rounded-full shadow-sm">
     Laporan Hasil Evaluasi Misi
   </div>
   <h2 id="congrats-text" class="text-2xl font-black text-indigo-950"></h2>
   <div id="total-score" class="text-5xl font-black text-indigo-600"></div>
   <div id="stars" class="text-3xl"></div>
   <div id="title-rank" class="text-lg font-bold text-indigo-800"></div>
   <div class="bg-indigo-50/50 border border-indigo-100 rounded-2xl p-4 w-full text-left text-sm space-y-2" id="eval-list"></div>
   <p class="text-xs text-slate-400 mt-2">Diverifikasi secara otomatis oleh Sistem Penilaian Sekolah</p>
   <button onclick="restart()" class="w-full px-8 py-3.5 rounded-2xl font-bold bg-indigo-600 text-white hover:bg-indigo-700 shadow-lg shadow-indigo-200">🔄 Main Lagi</button>
  </div>

  <script>
        let playerName = '';
        let scores = [0, 0, 0, 0];
        let currentScreen = 0;

        // Screen 0
        const nameInput = document.getElementById('name-input');
        const startBtn = document.getElementById('start-btn');
        nameInput.addEventListener('input', () => { startBtn.disabled = !nameInput.value.trim(); });
        startBtn.addEventListener('click', () => { playerName = nameInput.value.trim(); goScreen(1); });

        function goScreen(n) {
            document.getElementById('screen-' + currentScreen).classList.remove('active');
            currentScreen = n;
            const s = document.getElementById('screen-' + n);
            s.classList.remove('active');
            void s.offsetWidth;
            s.classList.add('active');
            if (n === 3) initLevel3();
            if (n === 5) showDashboard();
            updateScoreDisplays();
        }

        function updateScoreDisplays() {
            const total = scores.reduce((a, b) => a + b, 0);
            for (let i = 1; i <= 4; i++) {
                const el = document.getElementById('score-' + i);
                if (el) el.textContent = 'Skor: ' + total;
            }
        }

        // LEVEL 1
        const pattern = ['red', 'yellow', 'green', 'red', 'yellow', 'green'];
        let beads = [];
        const beadEmoji = { red: '🔴', yellow: '🟡', green: '🟢' };

        function addBead(color) {
            const expected = pattern[beads.length];
            if (color !== expected) {
                beads = [];
                renderBracelet();
                document.getElementById('bead-feedback').textContent = '❌ Salah urutan! Gelang putus, ulangi!';
                document.getElementById('bead-feedback').className = 'text-sm font-medium h-6 text-red-500';
                return;
            }
            beads.push(color);
            document.getElementById('bead-feedback').textContent = '';
            renderBracelet();
            if (beads.length === 6) {
                scores[0] = 250;
                document.getElementById('bead-feedback').textContent = '✅ Gelang sempurna! +250 poin';
                document.getElementById('bead-feedback').className = 'text-sm font-medium h-6 text-emerald-600';
                updateScoreDisplays();
                setTimeout(() => goScreen(2), 1200);
            }
        }

        function renderBracelet() {
            const el = document.getElementById('bracelet');
            if (beads.length === 0) { el.innerHTML = '<span class="text-slate-400 text-sm">Klik manik di bawah...</span>'; return; }
            el.innerHTML = beads.map(b => `<span class="text-2xl pop">${beadEmoji[b]}</span>`).join('');
        }

        // LEVEL 2
        let buckets = { A: { cap: 2, filled: false }, B: { cap: 2, filled: false }, C: { cap: 4, filled: false } };
        let taps = [null, null];
        let tapTimers = [null, null];
        let l2StartTime = 0;
        let l2Done = false;

        function assignBucket(name) {
            if (buckets[name].filled || l2Done) return;
            let tapIdx = taps[0] === null ? 0 : taps[1] === null ? 1 : -1;
            if (tapIdx === -1) { document.getElementById('tap-feedback').textContent = '⏳ Kedua keran sedang terpakai!'; return; }
            if (!l2StartTime) l2StartTime = Date.now();
            taps[tapIdx] = name;
            document.getElementById('bucket-' + name.toLowerCase() + '-btn').disabled = true;
            document.getElementById('tap' + (tapIdx + 1) + '-status').textContent = '🪣 ' + name;
            document.getElementById('tap-feedback').textContent = '';
            let progress = 0;
            const duration = buckets[name].cap * 500;
            const interval = 50;
            const increment = (interval / duration) * 100;
            tapTimers[tapIdx] = setInterval(() => {
                progress = Math.min(progress + increment, 100);
                document.getElementById('tap' + (tapIdx + 1) + '-bar').style.width = progress + '%';
                if (progress >= 100) {
                    clearInterval(tapTimers[tapIdx]);
                    buckets[name].filled = true;
                    taps[tapIdx] = null;
                    document.getElementById('tap' + (tapIdx + 1) + '-status').textContent = '✅ Selesai';
                    checkAllBuckets();
                }
            }, interval);
        }

        function checkAllBuckets() {
            if (buckets.A.filled && buckets.B.filled && buckets.C.filled) {
                l2Done = true;
                const elapsed = Date.now() - l2StartTime;
                let pts = elapsed < 5000 ? 250 : elapsed < 8000 ? 175 : 100;
                scores[1] = pts;
                document.getElementById('tap-feedback').textContent = '✅ Semua ember penuh! +' + pts + ' poin';
                document.getElementById('tap-feedback').className = 'text-sm font-medium h-6 text-emerald-600';
                updateScoreDisplays();
                setTimeout(() => goScreen(3), 1500);
            }
        }

        // LEVEL 3
        let slots = [];
        const answer3 = ['L', 'O', 'G', 'I', 'K', 'A'];

        function initLevel3() {
            slots = [];
            const bank = ['G', 'A', 'L', 'K', 'I', 'O'];
            const slotsEl = document.getElementById('word-slots');
            const bankEl = document.getElementById('letter-bank');
            slotsEl.innerHTML = '';
            bankEl.innerHTML = '';
            for (let i = 0; i < 6; i++) {
                slotsEl.innerHTML += `<div class="w-10 h-12 border-2 border-dashed border-indigo-300 rounded-lg flex items-center justify-center text-lg font-black" id="slot-${i}"></div>`;
            }
            bank.forEach(letter => {
                const btn = document.createElement('button');
                btn.className = 'w-10 h-12 rounded-lg font-black text-lg bg-indigo-50 border-2 border-indigo-200 hover:bg-indigo-100 shadow-sm text-indigo-900';
                btn.textContent = letter;
                btn.onclick = () => placeLetter(letter, btn);
                bankEl.appendChild(btn);
            });
        }

        function placeLetter(letter, btn) {
            if (slots.length >= 6) return;
            slots.push(letter);
            document.getElementById('slot-' + (slots.length - 1)).textContent = letter;
            btn.disabled = true;
            btn.classList.add('opacity-30');
            if (slots.length === 6) {
                const correct = slots.join('') === 'LOGIKA';
                if (correct) {
                    scores[2] = 250;
                    document.getElementById('word-feedback').textContent = '✅ Kata Rahasia: LOGIKA! +250 poin';
                    document.getElementById('word-feedback').className = 'text-sm font-medium h-6 text-emerald-600';
                } else {
                    document.getElementById('word-feedback').textContent = '❌ Urutan salah! Jawaban: LOGIKA';
                    document.getElementById('word-feedback').className = 'text-sm font-medium h-6 text-red-500';
                }
                updateScoreDisplays();
                setTimeout(() => goScreen(4), 1500);
            }
        }

        // LEVEL 4
        function answerRoom(slot) {
            if (slot === 2) {
                scores[3] = 250;
                document.getElementById('room-feedback').textContent = '✅ Benar! Slot 2 kosong di kedua hari. +250 poin';
                document.getElementById('room-feedback').className = 'text-sm font-medium h-6 text-emerald-600';
            } else {
                document.getElementById('room-feedback').textContent = '❌ Salah! Jawaban yang benar: Slot 2';
                document.getElementById('room-feedback').className = 'text-sm font-medium h-6 text-red-500';
            }
            updateScoreDisplays();
            setTimeout(() => goScreen(5), 1500);
        }

        // DASHBOARD
        function showDashboard() {
            const total = scores.reduce((a, b) => a + b, 0);
            document.getElementById('congrats-text').textContent = 'Selamat, Agen ' + playerName + '!';
            document.getElementById('total-score').textContent = total + ' / 1000';
            let stars, title;
            if (total >= 800) { stars = '⭐⭐⭐'; title = '🏆 CYBER LEGEND'; }
            else if (total >= 500) { stars = '⭐⭐'; title = '🎖️ CYBER AGENT'; }
            else { stars = '⭐'; title = '🔰 CYBER CADET'; }
            document.getElementById('stars').textContent = stars;
            document.getElementById('title-rank').textContent = title;
            const labels = ['Pertemuan 1 (Algoritma Gelang)', 'Pertemuan 2 (Optimasi Ember)', 'Pertemuan 3 (Struktur Data Kata Rahasia)', 'Pertemuan 4 (Representasi Peminjaman Ruang)'];
            document.getElementById('eval-list').innerHTML = labels.map((l, i) =>
                `<div class="flex justify-between"><span>${l}</span><span class="font-bold ${scores[i] > 0 ? 'text-emerald-600' : 'text-red-500'}">${scores[i] > 0 ? 'TUNTAS' : 'BELUM TUNTAS'}</span></div>`
            ).join('');
        }

        function restart() {
            scores = [0, 0, 0, 0];
            beads = [];
            buckets = { A: { cap: 2, filled: false }, B: { cap: 2, filled: false }, C: { cap: 4, filled: false } };
            taps = [null, null]; l2StartTime = 0; l2Done = false;
            document.getElementById('tap1-bar').style.width = '0%';
            document.getElementById('tap2-bar').style.width = '0%';
            document.getElementById('tap1-status').textContent = 'Kosong';
            document.getElementById('tap2-status').textContent = 'Kosong';
            ['a','b','c'].forEach(x => { const b = document.getElementById('bucket-'+x+'-btn'); b.disabled = false; });
            renderBracelet();
            document.getElementById('bead-feedback').textContent = '';
            document.getElementById('tap-feedback').textContent = '';
            document.getElementById('word-feedback').textContent = '';
            document.getElementById('room-feedback').textContent = '';
            nameInput.value = '';
            startBtn.disabled = true;
            goScreen(0);
        }

        lucide.createIcons();
    </script>
 </body>
</html>
